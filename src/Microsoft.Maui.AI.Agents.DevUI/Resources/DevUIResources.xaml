<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                    xmlns:local="clr-namespace:Microsoft.Maui.AI.Agents.DevUI"
                    x:Class="Microsoft.Maui.AI.Agents.DevUI.Resources.DevUIResources">

    <!-- === Brand Colors === -->
    <Color x:Key="DevUI.Primary">#643FB2</Color>
    <Color x:Key="DevUI.PrimaryLight">#8B5CF6</Color>
    <Color x:Key="DevUI.Success">#10B981</Color>
    <Color x:Key="DevUI.Error">#EF4444</Color>
    <Color x:Key="DevUI.Warning">#F97316</Color>
    <Color x:Key="DevUI.Info">#3B82F6</Color>

    <!-- === Theme-aware Colors === -->
    <Color x:Key="DevUI.Background">
        <Color.Light>#FFFFFF</Color.Light>
        <Color.Dark>#0f0d1a</Color.Dark>
    </Color>

    <Color x:Key="DevUI.Surface">
        <Color.Light>#f8f7fc</Color.Light>
        <Color.Dark>#12101e</Color.Dark>
    </Color>

    <Color x:Key="DevUI.SurfaceAlt">
        <Color.Light>#fafafa</Color.Light>
        <Color.Dark>#12121e</Color.Dark>
    </Color>

    <Color x:Key="DevUI.TextPrimary">
        <Color.Light>#1a1a2e</Color.Light>
        <Color.Dark>#f0f0f0</Color.Dark>
    </Color>

    <Color x:Key="DevUI.TextSecondary">
        <Color.Light>#666666</Color.Light>
        <Color.Dark>#aaaaaa</Color.Dark>
    </Color>

    <Color x:Key="DevUI.TextMuted">#808080</Color>

    <Color x:Key="DevUI.Border">
        <Color.Light>#e0e0e0</Color.Light>
        <Color.Dark>#2a2a3e</Color.Dark>
    </Color>

    <Color x:Key="DevUI.Divider">
        <Color.Light>#e0e0e0</Color.Light>
        <Color.Dark>#1e1e30</Color.Dark>
    </Color>

    <Color x:Key="DevUI.GraphEdge">
        <Color.Light>#9CA3AF</Color.Light>
        <Color.Dark>#6B7280</Color.Dark>
    </Color>

    <Color x:Key="DevUI.NodeBackground">
        <Color.Light>#fafafa</Color.Light>
        <Color.Dark>#1a1a2e</Color.Dark>
    </Color>

    <Color x:Key="DevUI.NodeBorder">#6B7280</Color>

    <Color x:Key="DevUI.UserBubble">
        <Color.Light>#e8e0f5</Color.Light>
        <Color.Dark>#3b2e6b</Color.Dark>
    </Color>

    <Color x:Key="DevUI.AssistantBubble">
        <Color.Light>#f5f5fa</Color.Light>
        <Color.Dark>#1e1e30</Color.Dark>
    </Color>

    <Color x:Key="DevUI.SelectedItem">
        <Color.Light>#643FB220</Color.Light>
        <Color.Dark>#643FB230</Color.Dark>
    </Color>

    <Color x:Key="DevUI.HowItWorksBg">
        <Color.Light>#f8f7fc</Color.Light>
        <Color.Dark>#1a1525</Color.Dark>
    </Color>

    <Color x:Key="DevUI.HowItWorksBorder">
        <Color.Light>#e8e0f0</Color.Light>
        <Color.Dark>#2a2040</Color.Dark>
    </Color>

    <!-- === Converters === -->
    <local:NodeBorderColorConverter x:Key="NodeBorderColorConverter" />
    <local:NodeBackgroundConverter x:Key="NodeBackgroundConverter" />
    <local:MessageBackgroundConverter x:Key="MessageBackgroundConverter" />
    <local:MessageAlignConverter x:Key="MessageAlignConverter" />
    <local:IsAssistantRoleConverter x:Key="IsAssistantRoleConverter" />
    <local:NotNullOrEmptyConverter x:Key="NotNullOrEmptyConverter" />
    <local:InvertBooleanConverter x:Key="InvertBooleanConverter" />
    <local:EventTypeColorConverter x:Key="EventTypeColorConverter" />
    <local:RunningOpacityConverter x:Key="RunningOpacityConverter" />
    <local:MarkdownCleanConverter x:Key="MarkdownCleanConverter" />
    <local:TabActiveColorConverter x:Key="TabActiveColorConverter" />
    <local:BoolToFontAttributeConverter x:Key="BoolToFontAttributeConverter" />

    <!-- === Base Styles === -->
    <Style x:Key="DevUI.SectionHeader" TargetType="Label">
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light=#999999, Dark=#777777}" />
        <Setter Property="Margin" Value="8,8,0,4" />
    </Style>

    <Style x:Key="DevUI.EntityName" TargetType="Label">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light=#1a1a2e, Dark=#f0f0f0}" />
    </Style>

    <Style x:Key="DevUI.EntityDescription" TargetType="Label">
        <Setter Property="FontSize" Value="10" />
        <Setter Property="TextColor" Value="{StaticResource DevUI.TextMuted}" />
        <Setter Property="LineBreakMode" Value="TailTruncation" />
        <Setter Property="MaxLines" Value="2" />
    </Style>

    <Style x:Key="DevUI.TabButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="TextColor" Value="{StaticResource DevUI.TextMuted}" />
    </Style>

    <Style x:Key="DevUI.TabButtonActive" TargetType="Button" BasedOn="{StaticResource DevUI.TabButton}">
        <Setter Property="TextColor" Value="{StaticResource DevUI.Primary}" />
        <Setter Property="FontAttributes" Value="Bold" />
    </Style>

    <Style x:Key="DevUI.SendButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource DevUI.Primary}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="WidthRequest" Value="40" />
        <Setter Property="HeightRequest" Value="40" />
        <Setter Property="FontSize" Value="16" />
    </Style>

</ResourceDictionary>
