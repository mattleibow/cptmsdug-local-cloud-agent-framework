<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Microsoft.Maui.AI.Agents.DevUI"
             x:Class="Microsoft.Maui.AI.Agents.DevUI.Controls.EmptyStateView"
             x:Name="self"
             x:DataType="local:Controls.EmptyStateView">

    <VerticalStackLayout Spacing="16"
                         Padding="32,24"
                         VerticalOptions="Center"
                         HorizontalOptions="Center"
                         MaximumWidthRequest="480">

        <!-- Icon -->
        <Border StrokeShape="RoundRectangle 12"
                BackgroundColor="{AppThemeBinding Light=#643FB215, Dark=#643FB225}"
                Stroke="{AppThemeBinding Light=#643FB240, Dark=#643FB250}"
                StrokeThickness="1"
                WidthRequest="56"
                HeightRequest="56"
                HorizontalOptions="Center">
            <Label Text="AG"
                   FontSize="20"
                   FontAttributes="Bold"
                   TextColor="{StaticResource DevUI.Primary}"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />
        </Border>

        <!-- Title -->
        <Label x:Name="TitleLabel"
               Text="{Binding Title, Source={x:Reference self}}"
               FontSize="18"
               FontAttributes="Bold"
               TextColor="{AppThemeBinding Light=#1a1a2e, Dark=#f0f0f0}"
               HorizontalOptions="Center"
               HorizontalTextAlignment="Center" />

        <!-- Description -->
        <Label x:Name="DescriptionLabel"
               Text="{Binding Description, Source={x:Reference self}}"
               FontSize="13"
               TextColor="{StaticResource DevUI.TextMuted}"
               HorizontalOptions="Center"
               HorizontalTextAlignment="Center"
               MaxLines="3"
               IsVisible="{Binding Description, Source={x:Reference self}, Converter={StaticResource NotNullOrEmptyConverter}}" />

        <!-- How it works -->
        <Border x:Name="HowItWorksBox"
                StrokeShape="RoundRectangle 10"
                BackgroundColor="{AppThemeBinding Light=#f8f7fc, Dark=#1a1525}"
                Stroke="{AppThemeBinding Light=#e8e0f0, Dark=#2a2040}"
                StrokeThickness="1"
                Padding="16,12"
                HorizontalOptions="Fill"
                IsVisible="{Binding HowItWorks, Source={x:Reference self}, Converter={StaticResource NotNullOrEmptyConverter}}">
            <VerticalStackLayout Spacing="6">
                <Label Text="How it works"
                       FontSize="12"
                       FontAttributes="Bold"
                       TextColor="{StaticResource DevUI.Primary}" />
                <Label Text="{Binding HowItWorks, Source={x:Reference self}}"
                       FontSize="12"
                       TextColor="{AppThemeBinding Light=#555555, Dark=#bbbbbb}"
                       LineBreakMode="WordWrap" />
            </VerticalStackLayout>
        </Border>

        <!-- Demo Prompt Chip -->
        <Border x:Name="DemoChip"
                StrokeShape="RoundRectangle 16"
                BackgroundColor="{AppThemeBinding Light=#643FB210, Dark=#643FB220}"
                Stroke="{StaticResource DevUI.Primary}"
                StrokeThickness="1"
                Padding="12,8"
                HorizontalOptions="Center"
                IsVisible="{Binding DemoPrompt, Source={x:Reference self}, Converter={StaticResource NotNullOrEmptyConverter}}">
            <HorizontalStackLayout Spacing="6">
                <Label Text="&#x25B6;"
                       FontSize="11"
                       TextColor="{StaticResource DevUI.Primary}"
                       VerticalOptions="Center" />
                <Label Text="{Binding DemoPrompt, Source={x:Reference self}}"
                       FontSize="12"
                       TextColor="{StaticResource DevUI.Primary}"
                       LineBreakMode="TailTruncation"
                       MaxLines="1"
                       MaximumWidthRequest="300" />
            </HorizontalStackLayout>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnDemoChipTapped" />
            </Border.GestureRecognizers>
        </Border>

    </VerticalStackLayout>

</ContentView>
