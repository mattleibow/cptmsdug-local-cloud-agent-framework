<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Microsoft.Maui.AI.Agents.DevUI"
             x:Class="Microsoft.Maui.AI.Agents.DevUI.Controls.EmptyStateView"
             x:Name="self"
             x:DataType="local:Controls.EmptyStateView">

    <VerticalStackLayout Spacing="12"
                         Padding="32,24"
                         VerticalOptions="Center"
                         HorizontalOptions="Center"
                         MaximumWidthRequest="400">

        <!-- Icon -->
        <Border StrokeShape="RoundRectangle 12"
                BackgroundColor="{AppThemeBinding Light=#643FB215, Dark=#643FB225}"
                Stroke="{AppThemeBinding Light=#643FB240, Dark=#643FB250}"
                StrokeThickness="1"
                WidthRequest="48"
                HeightRequest="48"
                HorizontalOptions="Center">
            <Label Text="&#x2726;"
                   FontSize="20"
                   TextColor="{StaticResource DevUI.Primary}"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />
        </Border>

        <!-- Title -->
        <Label Text="{Binding Title, Source={x:Reference self}}"
               FontSize="16"
               FontAttributes="Bold"
               TextColor="{AppThemeBinding Light=#1a1a2e, Dark=#f0f0f0}"
               HorizontalOptions="Center"
               HorizontalTextAlignment="Center" />

        <!-- Description -->
        <Label Text="{Binding Description, Source={x:Reference self}}"
               FontSize="13"
               TextColor="{StaticResource DevUI.TextMuted}"
               HorizontalOptions="Center"
               HorizontalTextAlignment="Center"
               LineBreakMode="WordWrap"
               IsVisible="{Binding Description, Source={x:Reference self}, Converter={StaticResource NotNullOrEmptyConverter}}" />

    </VerticalStackLayout>

</ContentView>
