<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Microsoft.Maui.AI.Agents.DevUI"
             x:Class="Microsoft.Maui.AI.Agents.DevUI.Controls.ChatInputBar"
             x:Name="self">

    <ContentView.Resources>
        <ResourceDictionary Source="../Resources/DevUIResources.xaml" />
    </ContentView.Resources>

    <Border StrokeShape="RoundRectangle 12"
            Stroke="{AppThemeBinding Light=#e0e0e0, Dark=#2a2a3e}"
            StrokeThickness="1"
            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1a1a2e}"
            Padding="12,8"
            Margin="16,8">
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <Entry x:Name="MessageEntry"
                   Placeholder="{Binding Placeholder, Source={x:Reference self}}"
                   FontSize="14"
                   VerticalOptions="Center"
                   IsEnabled="{Binding IsSending, Source={x:Reference self}, Converter={StaticResource InvertBooleanConverter}}"
                   Completed="OnEntryCompleted" />

            <Button Grid.Column="1"
                    Text="&#x27A4;"
                    Style="{StaticResource DevUI.SendButton}"
                    VerticalOptions="Center"
                    IsEnabled="{Binding IsSending, Source={x:Reference self}, Converter={StaticResource InvertBooleanConverter}}"
                    Clicked="OnSendClicked" />
        </Grid>
    </Border>

</ContentView>
