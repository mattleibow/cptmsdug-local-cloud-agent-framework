<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Microsoft.Maui.AI.Agents.DevUI"
             x:Class="Microsoft.Maui.AI.Agents.DevUI.Controls.DebugPanelView"
             x:Name="self"
             x:DataType="local:Controls.DebugPanelView"
             BackgroundColor="{AppThemeBinding Light=#fafafa, Dark=#12121e}">

    <Grid RowDefinitions="40,*">
        <!-- Tab Bar -->
        <Grid ColumnDefinitions="*,*,*" Padding="4,0">
            <Button Text="Events"
                    AutomationId="DevUI.Tab.Events"
                    Style="{StaticResource DevUI.TabButtonActive}"
                    x:Name="EventsTabBtn"
                    Clicked="OnEventsTabClicked" />
            <Button Grid.Column="1"
                    Text="Traces"
                    AutomationId="DevUI.Tab.Traces"
                    Style="{StaticResource DevUI.TabButton}"
                    x:Name="TracesTabBtn"
                    Clicked="OnTracesTabClicked" />
            <Button Grid.Column="2"
                    Text="Tools"
                    AutomationId="DevUI.Tab.Tools"
                    Style="{StaticResource DevUI.TabButton}"
                    x:Name="ToolsTabBtn"
                    Clicked="OnToolsTabClicked" />
        </Grid>

        <!-- Events List -->
        <CollectionView Grid.Row="1"
                        x:Name="EventsList"
                        Margin="8,4"
                        ItemsSource="{Binding Events, Source={x:Reference self}}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="local:DevUIEvent">
                    <Border StrokeShape="RoundRectangle 6"
                            Stroke="{AppThemeBinding Light=#e8e8e8, Dark=#2a2a3e}"
                            StrokeThickness="1"
                            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1a1a2e}"
                            Padding="8,6"
                            Margin="0,2">
                        <VerticalStackLayout Spacing="2">
                            <HorizontalStackLayout Spacing="6">
                                <Border StrokeShape="RoundRectangle 4"
                                        StrokeThickness="0"
                                        BackgroundColor="{Binding Type, Converter={StaticResource EventTypeColorConverter}}"
                                        Padding="4,1">
                                    <Label Text="{Binding Type}"
                                           FontSize="9"
                                           TextColor="White" />
                                </Border>
                                <Label Text="{Binding Timestamp, StringFormat='{0:HH:mm:ss}'}"
                                       FontSize="9"
                                       TextColor="{StaticResource DevUI.TextMuted}" />
                            </HorizontalStackLayout>
                            <Label Text="{Binding Description}"
                                   FontSize="11"
                                   TextColor="{AppThemeBinding Light=#333333, Dark=#cccccc}"
                                   LineBreakMode="TailTruncation"
                                   MaxLines="2" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Traces List -->
        <CollectionView Grid.Row="1"
                        x:Name="TracesList"
                        Margin="8,4"
                        IsVisible="False"
                        ItemsSource="{Binding Traces, Source={x:Reference self}}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="local:DevUITraceSpan">
                    <Border StrokeShape="RoundRectangle 6"
                            Stroke="{AppThemeBinding Light=#e8e8e8, Dark=#2a2a3e}"
                            StrokeThickness="1"
                            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1a1a2e}"
                            Padding="8,6"
                            Margin="0,2">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Border StrokeShape="RoundRectangle 4"
                                    StrokeThickness="0"
                                    BackgroundColor="{Binding OperationColor}"
                                    Padding="4,1"
                                    VerticalOptions="Center">
                                <Label Text="{Binding OperationKind}"
                                       FontSize="9"
                                       TextColor="White" />
                            </Border>
                            <Label Grid.Column="1"
                                   Text="{Binding Name}"
                                   FontSize="11"
                                   TextColor="{AppThemeBinding Light=#333333, Dark=#cccccc}"
                                   VerticalOptions="Center"
                                   Margin="8,0,0,0" />
                            <Label Grid.Column="2"
                                   Text="{Binding Duration, StringFormat='{0}ms'}"
                                   FontSize="9"
                                   TextColor="{StaticResource DevUI.TextMuted}"
                                   VerticalOptions="Center" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Tools List -->
        <CollectionView Grid.Row="1"
                        x:Name="ToolsList"
                        Margin="8,4"
                        IsVisible="False"
                        ItemsSource="{Binding ToolCalls, Source={x:Reference self}}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="local:DevUIToolCall">
                    <Border StrokeShape="RoundRectangle 6"
                            Stroke="{AppThemeBinding Light=#e8e8e8, Dark=#2a2a3e}"
                            StrokeThickness="1"
                            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1a1a2e}"
                            Padding="8,6"
                            Margin="0,2">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnToolCallTapped" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="2">
                            <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="6">
                                <Label Grid.Column="0"
                                       Text="{Binding Name}"
                                       FontSize="11"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource DevUI.Info}" />
                                <Label Grid.Column="2"
                                       Text="{Binding Timestamp, StringFormat='{0:HH:mm:ss}'}"
                                       FontSize="9"
                                       VerticalOptions="Center"
                                       TextColor="{StaticResource DevUI.TextMuted}" />
                                <Label Grid.Column="3"
                                       FontSize="10"
                                       VerticalOptions="Center"
                                       TextColor="{StaticResource DevUI.TextMuted}">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsExpanded}" Value="True">
                                            <Setter Property="Text" Value="▾" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsExpanded}" Value="False">
                                            <Setter Property="Text" Value="▸" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                            </Grid>
                            <Label Text="{Binding Arguments}"
                                   FontSize="10"
                                   TextColor="{AppThemeBinding Light=#555555, Dark=#999999}"
                                   FontFamily="Courier New">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsExpanded}" Value="True">
                                        <Setter Property="LineBreakMode" Value="WordWrap" />
                                        <Setter Property="MaxLines" Value="-1" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsExpanded}" Value="False">
                                        <Setter Property="LineBreakMode" Value="TailTruncation" />
                                        <Setter Property="MaxLines" Value="2" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                            <BoxView HeightRequest="1"
                                     Color="{AppThemeBinding Light=#e8e8e8, Dark=#2a2a3e}"
                                     Margin="0,2"
                                     IsVisible="{Binding Result, Converter={StaticResource NotNullOrEmptyConverter}}" />
                            <Label Text="{Binding Result}"
                                   FontSize="10"
                                   TextColor="{AppThemeBinding Light=#2e7d32, Dark=#81c784}"
                                   FontFamily="Courier New"
                                   IsVisible="{Binding Result, Converter={StaticResource NotNullOrEmptyConverter}}">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsExpanded}" Value="True">
                                        <Setter Property="LineBreakMode" Value="WordWrap" />
                                        <Setter Property="MaxLines" Value="-1" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsExpanded}" Value="False">
                                        <Setter Property="LineBreakMode" Value="TailTruncation" />
                                        <Setter Property="MaxLines" Value="3" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>

</ContentView>
