<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Microsoft.Maui.AI.Agents.DevUI"
             xmlns:controls="clr-namespace:Microsoft.Maui.AI.Agents.DevUI.Controls"
             xmlns:graph="clr-namespace:Microsoft.Maui.AI.Agents.DevUI.Graph"
             x:Class="Microsoft.Maui.AI.Agents.DevUI.AgentDevUIView"
             x:Name="self"
             x:DataType="local:AgentDevUIView"
             BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#0f0d1a}">

    <Grid RowDefinitions="48,*"
          BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#0f0d1a}">

        <!-- ===== HEADER ===== -->
        <Grid Grid.Row="0"
              BackgroundColor="{AppThemeBinding Light=#f8f7fc, Dark=#12101e}"
              ColumnDefinitions="Auto,*,Auto,Auto"
              Padding="16,0">
            <!-- Picker trigger button -->
            <Border StrokeShape="RoundRectangle 8"
                    Stroke="{AppThemeBinding Light=#e0e0e0, Dark=#2a2a3e}"
                    StrokeThickness="1"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1a1a2e}"
                    Padding="10,6"
                    VerticalOptions="Center">
                <HorizontalStackLayout Spacing="8">
                    <Label Text="AG"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="{StaticResource DevUI.Primary}"
                           VerticalOptions="Center" />
                    <Label x:Name="HeaderTitle"
                           Text="Select agent..."
                           FontSize="13"
                           TextColor="{AppThemeBinding Light=#1a1a2e, Dark=#f0f0f0}"
                           VerticalOptions="Center" />
                    <Label Text="&#x25BC;"
                           FontSize="9"
                           TextColor="{StaticResource DevUI.TextMuted}"
                           VerticalOptions="Center" />
                </HorizontalStackLayout>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnPickerTapped" />
                </Border.GestureRecognizers>
            </Border>

            <!-- Column 1 (*) is empty - acts as spacer -->

            <!-- Clear button -->
            <Button Grid.Column="2"
                    Text="Clear"
                    AutomationId="DevUI.ClearButton"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource DevUI.TextMuted}"
                    FontSize="11"
                    Clicked="OnClearClicked"
                    VerticalOptions="Center" />

            <!-- Token counter -->
            <Label x:Name="TokenLabel"
                   Grid.Column="3"
                   Text="0 tokens"
                   FontSize="10"
                   TextColor="{StaticResource DevUI.TextMuted}"
                   VerticalOptions="Center"
                   Margin="12,0,0,0" />
        </Grid>

        <!-- ===== MAIN CONTENT ===== -->
        <Grid Grid.Row="1"
              x:Name="MainContentGrid"
              ColumnDefinitions="*,1,360">

            <!-- Left area: Graph + Chat stacked -->
            <Grid x:Name="LeftArea"
                  ColumnDefinitions="Auto,1,*">

                <!-- Workflow Graph Panel (visible only when workflow selected) -->
                <graph:GraphView x:Name="WorkflowGraphView"
                                 IsVisible="False"
                                 MinimumWidthRequest="280"
                                 WidthRequest="320"
                                 BackgroundColor="{AppThemeBinding Light=#f8f7fc, Dark=#12101e}" />

                <!-- Graph splitter -->
                <BoxView x:Name="GraphSplitter"
                         Grid.Column="1"
                         Color="{AppThemeBinding Light=#e0e0e0, Dark=#1e1e30}"
                         WidthRequest="1"
                         IsVisible="False" />

                <!-- Chat Panel -->
                <controls:ChatPanelView x:Name="ChatPanel"
                                        Grid.Column="2"
                                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#0f0d1a}" />
            </Grid>

            <!-- Right splitter -->
            <BoxView Grid.Column="1"
                     Color="{AppThemeBinding Light=#e0e0e0, Dark=#1e1e30}"
                     WidthRequest="1" />

            <!-- Debug Panel -->
            <controls:DebugPanelView x:Name="DebugPanel"
                                     Grid.Column="2"
                                     BackgroundColor="{AppThemeBinding Light=#fafafa, Dark=#12121e}" />
        </Grid>

        <!-- ===== PICKER OVERLAY (Left Sidebar Tray) ===== -->
        <Border x:Name="PickerOverlay"
                Grid.Row="1"
                IsVisible="False"
                StrokeShape="RoundRectangle 0,12,0,12"
                Stroke="{AppThemeBinding Light=#e0e0e0, Dark=#2a2a3e}"
                StrokeThickness="1"
                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1a1a2e}"
                HorizontalOptions="Start"
                VerticalOptions="Fill"
                WidthRequest="280"
                Padding="0"
                ZIndex="100">
            <Grid RowDefinitions="44,*">
                <!-- Overlay header -->
                <Grid ColumnDefinitions="*,Auto" Padding="16,8">
                    <Label Text="Select Agent or Workflow"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#1a1a2e, Dark=#f0f0f0}"
                           VerticalOptions="Center" />
                    <Button Grid.Column="1"
                            Text="&#x2715;"
                            BackgroundColor="Transparent"
                            TextColor="{StaticResource DevUI.TextMuted}"
                            FontSize="14"
                            Clicked="OnPickerDismissed"
                            VerticalOptions="Center" />
                </Grid>

                <!-- Selector content -->
                <ScrollView Grid.Row="1">
                    <controls:AgentSelectorView x:Name="SelectorView" />
                </ScrollView>
            </Grid>
        </Border>

    </Grid>

</ContentView>
