<Shell
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Demo2.MauiAgent.AppShell"
    xmlns:local="clr-namespace:Demo2.MauiAgent"
    Title="Agent DevUI"
    Shell.FlyoutBehavior="Disabled">

    <TabBar>
        <ShellContent
            Title="Agent DevUI"
            Shell.NavBarIsVisible="False"
            ContentTemplate="{DataTemplate local:MainPage}"
            Route="MainPage" />
        <ShellContent
            Title="Graph Test"
            ContentTemplate="{DataTemplate local:GraphTestPage}"
            Route="GraphTestPage" />
    </TabBar>

</Shell>
