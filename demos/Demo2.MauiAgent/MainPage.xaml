<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Demo2.MauiAgent.ViewModels"
             xmlns:models="clr-namespace:Demo2.MauiAgent.Models"
             x:Class="Demo2.MauiAgent.MainPage"
             x:DataType="vm:MainViewModel"
             Title="Agent Framework Dev UI">

    <ContentPage.Resources>
        <ResourceDictionary>
            <local:IsPublisherConverter x:Key="IsPublisherConverter" xmlns:local="clr-namespace:Demo2.MauiAgent.Converters"/>
            <local:StepBorderConverter x:Key="StepBorderConverter" xmlns:local="clr-namespace:Demo2.MauiAgent.Converters"/>
            <local:StepBgConverter x:Key="StepBgConverter" xmlns:local="clr-namespace:Demo2.MauiAgent.Converters"/>
            <local:MessageBgConverter x:Key="MessageBgConverter" xmlns:local="clr-namespace:Demo2.MauiAgent.Converters"/>
            <local:MessageAlignConverter x:Key="MessageAlignConverter" xmlns:local="clr-namespace:Demo2.MauiAgent.Converters"/>
            <local:NotNullConverter x:Key="NotNullConverter" xmlns:local="clr-namespace:Demo2.MauiAgent.Converters"/>
            <local:InvertBoolConverter x:Key="InvertBoolConverter" xmlns:local="clr-namespace:Demo2.MauiAgent.Converters"/>
            <local:EventTypeColorConverter x:Key="EventTypeColorConverter" xmlns:local="clr-namespace:Demo2.MauiAgent.Converters"/>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid ColumnDefinitions="*,1,350" RowDefinitions="50,*">

        <!-- Header -->
        <Grid Grid.Row="0" Grid.ColumnSpan="3" 
              BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark=#1e1e2e}"
              Padding="16,8" ColumnDefinitions="Auto,*,Auto">
            <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                <Label Text="&#x1F916; Dev UI" FontSize="16" FontAttributes="Bold" VerticalOptions="Center"/>
                <Label Text="v0.1.0" FontSize="11" TextColor="Gray" VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <HorizontalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="8" VerticalOptions="Center">
                <Picker x:Name="agentPicker" 
                        ItemsSource="{Binding Agents}" 
                        SelectedItem="{Binding SelectedAgent}"
                        WidthRequest="150"/>
            </HorizontalStackLayout>

            <Button Grid.Column="2" Text="New Chat" 
                    Command="{Binding ClearConversationCommand}"
                    BackgroundColor="Transparent" TextColor="Gray"
                    FontSize="12" VerticalOptions="Center"/>
        </Grid>

        <!-- Left Panel: Chat + Workflow -->
        <Grid Grid.Row="1" Grid.Column="0" RowDefinitions="Auto,*,Auto">

            <!-- Workflow Steps (visible when publisher selected) -->
            <Border Grid.Row="0" Padding="12" Margin="12,8,12,0"
                    StrokeShape="RoundRectangle 8"
                    Stroke="{AppThemeBinding Light=#e0e0e0, Dark=#333}"
                    BackgroundColor="{AppThemeBinding Light=#f8f8fc, Dark=#22223a}"
                    IsVisible="{Binding SelectedAgent, Converter={StaticResource IsPublisherConverter}}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Workflow: publisher" FontSize="12" FontAttributes="Bold"/>
                    <HorizontalStackLayout Spacing="8" x:Name="workflowStepsLayout"
                                           BindableLayout.ItemsSource="{Binding WorkflowSteps}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:WorkflowStep" 
                                          xmlns:models="clr-namespace:Demo2.MauiAgent.Models">
                                <Border Stroke="{Binding Status, Converter={StaticResource StepBorderConverter}}"
                                       BackgroundColor="{Binding Status, Converter={StaticResource StepBgConverter}}"
                                       StrokeShape="RoundRectangle 6" Padding="10,6" MinimumWidthRequest="100">
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="12"/>
                                        <Label Text="{Binding Status}" FontSize="10" TextColor="Gray"/>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Chat Messages -->
            <CollectionView Grid.Row="1" ItemsSource="{Binding Messages}" 
                            x:Name="messagesCollection"
                            Margin="16,8">
                <CollectionView.EmptyView>
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="8">
                        <Label Text="{Binding SelectedAgent, StringFormat='Chat with {0}'}" 
                               FontSize="20" FontAttributes="Bold" HorizontalOptions="Center"/>
                        <Label Text="Type a message below to begin" 
                               TextColor="Gray" FontSize="14" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:UIChatMessage"
                                  xmlns:models="clr-namespace:Demo2.MauiAgent.Models">
                        <Grid Padding="0,4">
                            <Border StrokeShape="RoundRectangle 12" Padding="12,10"
                                   BackgroundColor="{Binding Role, Converter={StaticResource MessageBgConverter}}"
                                   HorizontalOptions="{Binding Role, Converter={StaticResource MessageAlignConverter}}"
                                   MaximumWidthRequest="600"
                                   Stroke="Transparent">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="{Binding Content}" FontSize="14"/>
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="{Binding Timestamp, StringFormat='{0:h:mm:ss tt}'}" 
                                               FontSize="10" TextColor="Gray"/>
                                        <Label Text="{Binding TokenCount, StringFormat='({0} tokens)'}" 
                                               FontSize="10" TextColor="Gray"
                                               IsVisible="{Binding TokenCount, Converter={StaticResource NotNullConverter}}"/>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Message Input -->
            <Grid Grid.Row="2" Padding="16,8,16,16" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Border StrokeShape="RoundRectangle 8" Stroke="{AppThemeBinding Light=#ccc, Dark=#555}" Padding="8,0">
                    <Entry x:Name="messageEntry"
                           Text="{Binding MessageText}" 
                           Placeholder="{Binding SelectedAgent, StringFormat='Message {0}... (Enter to send)'}"
                           ReturnCommand="{Binding SendMessageCommand}"
                           IsEnabled="{Binding IsSending, Converter={StaticResource InvertBoolConverter}}"/>
                </Border>
                <Button Grid.Column="1" Text="&#x27A4;" 
                        Command="{Binding SendMessageCommand}"
                        IsEnabled="{Binding IsSending, Converter={StaticResource InvertBoolConverter}}"
                        BackgroundColor="#7c3aed" TextColor="White"
                        CornerRadius="8" WidthRequest="44" HeightRequest="44"
                        FontSize="18"/>
            </Grid>
        </Grid>

        <!-- Splitter -->
        <BoxView Grid.Row="1" Grid.Column="1" 
                 Color="{AppThemeBinding Light=#e0e0e0, Dark=#333}"/>

        <!-- Right Panel: Events -->
        <Grid Grid.Row="1" Grid.Column="2" RowDefinitions="40,*" 
              BackgroundColor="{AppThemeBinding Light=#fafafa, Dark=#1a1a2e}">

            <!-- Tab Header -->
            <Grid Grid.Row="0" Padding="12,0" ColumnDefinitions="*,*">
                <Label Text="{Binding EventCount, StringFormat='Events {0}'}" 
                       FontSize="12" FontAttributes="Bold" VerticalOptions="Center"/>
                <Label Grid.Column="1" Text="{Binding ToolCalls.Count, StringFormat='Tools {0}'}"
                       FontSize="12" TextColor="Gray" VerticalOptions="Center"
                       HorizontalOptions="End"/>
            </Grid>
            <BoxView Grid.Row="0" HeightRequest="1" VerticalOptions="End"
                     Color="{AppThemeBinding Light=#e0e0e0, Dark=#333}"/>

            <!-- Events List -->
            <CollectionView Grid.Row="1" ItemsSource="{Binding Events}" Margin="8,4">
                <CollectionView.EmptyView>
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Padding="16">
                        <Label Text="No events yet." TextColor="Gray" FontSize="13" HorizontalOptions="Center"/>
                        <Label Text="Start a conversation to see real-time events." 
                               TextColor="Gray" FontSize="11" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:AgentEvent"
                                  xmlns:models="clr-namespace:Demo2.MauiAgent.Models">
                        <Grid Padding="4,3" ColumnDefinitions="55,*" ColumnSpacing="6">
                            <Label Text="{Binding Timestamp, StringFormat='{0:h:mm:ss}'}" 
                                   FontSize="10" TextColor="Gray" VerticalOptions="Start"/>
                            <VerticalStackLayout Grid.Column="1" Spacing="1">
                                <Label Text="{Binding Type}" FontSize="11" 
                                       FontAttributes="Bold"
                                       TextColor="{Binding Type, Converter={StaticResource EventTypeColorConverter}}"/>
                                <Label Text="{Binding Description}" FontSize="11" 
                                       TextColor="{AppThemeBinding Light=#555, Dark=#aaa}"
                                       LineBreakMode="TailTruncation" MaxLines="2"/>
                            </VerticalStackLayout>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </Grid>

</ContentPage>
