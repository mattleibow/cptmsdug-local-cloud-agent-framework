<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Demo2.MauiAgent.ViewModels"
             xmlns:models="clr-namespace:Demo2.MauiAgent.Models"
             xmlns:local="clr-namespace:Demo2.MauiAgent.Converters"
             x:Class="Demo2.MauiAgent.MainPage"
             x:DataType="vm:MainViewModel"
             Title="Agent Framework Dev UI">

    <ContentPage.Resources>
        <ResourceDictionary>
            <local:StepBorderConverter x:Key="StepBorderConverter"/>
            <local:StepBgConverter x:Key="StepBgConverter"/>
            <local:MessageBgConverter x:Key="MessageBgConverter"/>
            <local:MessageAlignConverter x:Key="MessageAlignConverter"/>
            <local:NotNullConverter x:Key="NotNullConverter"/>
            <local:InvertBoolConverter x:Key="InvertBoolConverter"/>
            <local:EventTypeColorConverter x:Key="EventTypeColorConverter"/>
            <local:BoolToFontAttributeConverter x:Key="BoolToFontAttr"/>
            <local:TabActiveColorConverter x:Key="TabActiveColor"/>
            <local:IsAssistantConverter x:Key="IsAssistantConverter"/>
            <local:IsUserConverter x:Key="IsUserConverter"/>
            <local:RunningOpacityConverter x:Key="RunningOpacityConverter"/>
            <local:MarkdownStripConverter x:Key="MarkdownStripConverter"/>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid ColumnDefinitions="*,1,380" RowDefinitions="48,*">

        <!-- ═══════════ HEADER ═══════════ -->
        <Border Grid.Row="0" Grid.ColumnSpan="3" 
                StrokeThickness="0"
                BackgroundColor="{AppThemeBinding Light=#faf8ff, Dark=#1a1025}">
            <Grid Padding="16,0" ColumnDefinitions="Auto,*,Auto,Auto">
                <!-- Brand -->
                <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                    <Border StrokeShape="RoundRectangle 6" BackgroundColor="#643FB2" 
                            Padding="6,4" StrokeThickness="0">
                        <Label Text="AG" FontSize="12" FontAttributes="Bold" TextColor="White"/>
                    </Border>
                    <Label Text="Agent Framework" FontSize="15" FontAttributes="Bold" 
                           TextColor="{AppThemeBinding Light=#1a1a2e, Dark=#f0f0f0}" VerticalOptions="Center"/>
                    <Border StrokeShape="RoundRectangle 4" Stroke="#643FB2" 
                            BackgroundColor="#643FB215" Padding="6,2" StrokeThickness="1">
                        <Label Text="Dev UI" FontSize="10" TextColor="#643FB2" FontAttributes="Bold"/>
                    </Border>
                </HorizontalStackLayout>

                <!-- Agent Picker -->
                <HorizontalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="8" VerticalOptions="Center">
                    <Label Text="Agent:" FontSize="12" TextColor="Gray" VerticalOptions="Center"/>
                    <Picker ItemsSource="{Binding Agents}" 
                            SelectedItem="{Binding SelectedAgent}"
                            WidthRequest="280" VerticalOptions="Center"/>
                </HorizontalStackLayout>

                <!-- Theme Toggle -->
                <Button Grid.Column="2" Text="{Binding ThemeIcon}" 
                        Command="{Binding ToggleThemeCommand}"
                        BackgroundColor="Transparent" 
                        TextColor="{AppThemeBinding Light=#666, Dark=#aaa}"
                        FontSize="18" WidthRequest="40" HeightRequest="40"
                        VerticalOptions="Center"/>

                <!-- New Chat -->
                <Button Grid.Column="3" Text="＋ New Chat" 
                        Command="{Binding ClearConversationCommand}"
                        BackgroundColor="Transparent" 
                        TextColor="{AppThemeBinding Light=#643FB2, Dark=#8B5CF6}"
                        FontSize="12" VerticalOptions="Center" Padding="8,4"/>
            </Grid>
        </Border>
        <!-- Header bottom border -->
        <BoxView Grid.Row="0" Grid.ColumnSpan="3" HeightRequest="1" VerticalOptions="End"
                 Color="{AppThemeBinding Light=#e8e0f0, Dark=#2a2040}"/>

        <!-- ═══════════ LEFT PANEL: WORKFLOW + CHAT ═══════════ -->
        <Grid Grid.Row="1" Grid.Column="0" RowDefinitions="Auto,*,Auto"
              BackgroundColor="{AppThemeBinding Light=#ffffff, Dark=#0f0f1a}">

            <!-- Workflow Graph (visible when workflow selected) -->
            <Border Grid.Row="0" Padding="16,12" Margin="16,12,16,0"
                    StrokeShape="RoundRectangle 10"
                    Stroke="{AppThemeBinding Light=#e8e0f0, Dark=#2a2040}"
                    BackgroundColor="{AppThemeBinding Light=#faf8ff, Dark=#1a1025}"
                    IsVisible="{Binding IsWorkflow}">
                <VerticalStackLayout Spacing="10">
                    <!-- Workflow header -->
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="⚙️" FontSize="14"/>
                        <Label Text="{Binding WorkflowTitle}" FontSize="13" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#643FB2, Dark=#8B5CF6}"/>
                        <Border StrokeShape="RoundRectangle 4" BackgroundColor="#643FB215"
                                Stroke="Transparent" Padding="6,2">
                            <Label Text="{Binding OrchestrationKindLabel}" FontSize="9" TextColor="#8B5CF6"/>
                        </Border>
                    </HorizontalStackLayout>
                    <!-- Graph with connectors -->
                    <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                        <HorizontalStackLayout Spacing="0" x:Name="workflowStepsLayout"
                                               BindableLayout.ItemsSource="{Binding WorkflowSteps}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="models:WorkflowStep">
                                    <HorizontalStackLayout Spacing="0">
                                        <!-- Connector arrow (hidden for first item) -->
                                        <Label Text="→" FontSize="16" VerticalOptions="Center" 
                                               Margin="4,0"
                                               TextColor="{Binding Status, Converter={StaticResource StepBorderConverter}}"
                                               IsVisible="{Binding IsFirst, Converter={StaticResource InvertBoolConverter}}"/>
                                        <!-- Node -->
                                        <Border Stroke="{Binding Status, Converter={StaticResource StepBorderConverter}}"
                                               BackgroundColor="{Binding Status, Converter={StaticResource StepBgConverter}}"
                                               StrokeShape="RoundRectangle 8" StrokeThickness="2"
                                               Padding="12,8" MinimumWidthRequest="110">
                                            <Border.Shadow>
                                                <Shadow Brush="{Binding Status, Converter={StaticResource StepBorderConverter}}"
                                                        Offset="0,2" Radius="8"
                                                        Opacity="{Binding IsRunning, Converter={StaticResource RunningOpacityConverter}}"/>
                                            </Border.Shadow>
                                            <VerticalStackLayout Spacing="3">
                                                <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="12"
                                                       TextColor="{AppThemeBinding Light=#1a1a2e, Dark=#f0f0f0}"/>
                                                <HorizontalStackLayout Spacing="4">
                                                    <Label Text="{Binding StatusIcon}" FontSize="10"/>
                                                    <Label Text="{Binding StatusLabel}" FontSize="10" 
                                                           TextColor="{Binding Status, Converter={StaticResource StepBorderConverter}}"/>
                                                </HorizontalStackLayout>
                                            </VerticalStackLayout>
                                        </Border>
                                    </HorizontalStackLayout>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </HorizontalStackLayout>
                    </ScrollView>
                </VerticalStackLayout>
            </Border>

            <!-- Chat Messages -->
            <CollectionView Grid.Row="1" ItemsSource="{Binding Messages}" 
                            x:Name="messagesCollection"
                            Margin="16,8">
                <CollectionView.EmptyView>
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="12">
                        <Border StrokeShape="RoundRectangle 20" BackgroundColor="#643FB215"
                                Padding="20" StrokeThickness="0" HorizontalOptions="Center">
                            <Label Text="🤖" FontSize="36" HorizontalOptions="Center"/>
                        </Border>
                        <Label Text="{Binding SelectedAgent, StringFormat='Chat with {0}'}" 
                               FontSize="20" FontAttributes="Bold" HorizontalOptions="Center"
                               TextColor="{AppThemeBinding Light=#643FB2, Dark=#8B5CF6}"/>
                        <Label Text="Type a message below to start the conversation" 
                               TextColor="Gray" FontSize="13" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:UIChatMessage">
                        <Grid Padding="0,4" ColumnDefinitions="Auto,*" ColumnSpacing="8">
                            <!-- Avatar for assistant messages -->
                            <Border StrokeShape="RoundRectangle 6" WidthRequest="28" HeightRequest="28"
                                    StrokeThickness="1" VerticalOptions="Start" Margin="0,4,0,0"
                                    Stroke="{AppThemeBinding Light=#e0e0e0, Dark=#333}"
                                    BackgroundColor="{AppThemeBinding Light=#f0eef5, Dark=#2a2040}"
                                    IsVisible="{Binding Role, Converter={StaticResource IsAssistantConverter}}">
                                <Label Text="AG" FontSize="9" FontAttributes="Bold" 
                                       TextColor="#643FB2" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <!-- Message bubble -->
                            <Border Grid.Column="1" StrokeShape="RoundRectangle 12" Padding="14,10"
                                   BackgroundColor="{Binding Role, Converter={StaticResource MessageBgConverter}}"
                                   HorizontalOptions="{Binding Role, Converter={StaticResource MessageAlignConverter}}"
                                   MaximumWidthRequest="650"
                                   Stroke="Transparent">
                                <VerticalStackLayout Spacing="4">
                                    <!-- Agent label for workflow messages -->
                                    <Label Text="{Binding AgentLabel}" FontSize="11" 
                                           FontAttributes="Bold" TextColor="#643FB2"
                                           IsVisible="{Binding AgentLabel, Converter={StaticResource NotNullConverter}}"/>
                                    <Label Text="{Binding Content, Converter={StaticResource MarkdownStripConverter}}" FontSize="14"
                                           TextColor="{AppThemeBinding Light=#1a1a2e, Dark=#e8e8e8}"/>
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="{Binding Timestamp, StringFormat='{0:h:mm:ss tt}'}" 
                                               FontSize="9" TextColor="Gray"/>
                                        <Label Text="{Binding TokenCount, StringFormat='• {0} tokens'}" 
                                               FontSize="9" TextColor="Gray"
                                               IsVisible="{Binding TokenCount, Converter={StaticResource NotNullConverter}}"/>
                                        <!-- Streaming indicator -->
                                        <Label Text="●" FontSize="8" TextColor="#643FB2"
                                               IsVisible="{Binding IsStreaming}"/>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Message Input -->
            <Border Grid.Row="2" Margin="16,0,16,16" Padding="4"
                    StrokeShape="RoundRectangle 12" 
                    Stroke="{AppThemeBinding Light=#d0c8e0, Dark=#3a3050}"
                    BackgroundColor="{AppThemeBinding Light=#faf8ff, Dark=#1a1025}">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" Padding="8,0">
                    <Entry x:Name="messageEntry"
                           Text="{Binding MessageText}" 
                           Placeholder="{Binding SelectedAgent, StringFormat='Message {0}...'}"
                           ReturnCommand="{Binding SendMessageCommand}"
                           IsEnabled="{Binding IsSending, Converter={StaticResource InvertBoolConverter}}"
                           FontSize="14" VerticalOptions="Center"/>
                    <Button Grid.Column="1" Text="➤" 
                            Command="{Binding SendMessageCommand}"
                            IsEnabled="{Binding IsSending, Converter={StaticResource InvertBoolConverter}}"
                            BackgroundColor="#643FB2" TextColor="White"
                            CornerRadius="10" WidthRequest="40" HeightRequest="40"
                            FontSize="16" VerticalOptions="Center"/>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══════════ SPLITTER ═══════════ -->
        <BoxView Grid.Row="1" Grid.Column="1" 
                 Color="{AppThemeBinding Light=#e8e0f0, Dark=#2a2040}"/>

        <!-- ═══════════ RIGHT PANEL: TABBED DEBUG ═══════════ -->
        <Grid Grid.Row="1" Grid.Column="2" RowDefinitions="40,*,Auto" 
              BackgroundColor="{AppThemeBinding Light=#fafafa, Dark=#12121e}">

            <!-- Tab Bar -->
            <Grid Grid.Row="0" ColumnDefinitions="*,*,*" Padding="4,0">
                <Button Text="{Binding EventCount, StringFormat='Events ({0})'}"
                        Command="{Binding SwitchTabCommand}" CommandParameter="events"
                        BackgroundColor="Transparent" FontSize="11" Padding="0"
                        TextColor="{Binding IsEventsTab, Converter={StaticResource TabActiveColor}}"
                        FontAttributes="{Binding IsEventsTab, Converter={StaticResource BoolToFontAttr}}"/>
                <Button Grid.Column="1" Text="{Binding TraceCount, StringFormat='Traces ({0})'}"
                        Command="{Binding SwitchTabCommand}" CommandParameter="traces"
                        BackgroundColor="Transparent" FontSize="11" Padding="0"
                        TextColor="{Binding IsTracesTab, Converter={StaticResource TabActiveColor}}"
                        FontAttributes="{Binding IsTracesTab, Converter={StaticResource BoolToFontAttr}}"/>
                <Button Grid.Column="2" Text="{Binding ToolCalls.Count, StringFormat='Tools ({0})'}"
                        Command="{Binding SwitchTabCommand}" CommandParameter="tools"
                        BackgroundColor="Transparent" FontSize="11" Padding="0"
                        TextColor="{Binding IsToolsTab, Converter={StaticResource TabActiveColor}}"
                        FontAttributes="{Binding IsToolsTab, Converter={StaticResource BoolToFontAttr}}"/>
            </Grid>
            <BoxView Grid.Row="0" HeightRequest="1" VerticalOptions="End"
                     Color="{AppThemeBinding Light=#e8e0f0, Dark=#2a2040}"/>

            <!-- Events Tab Content -->
            <CollectionView Grid.Row="1" ItemsSource="{Binding Events}" Margin="8,4"
                            IsVisible="{Binding IsEventsTab}">
                <CollectionView.EmptyView>
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Padding="20">
                        <Label Text="📡" FontSize="28" HorizontalOptions="Center" Margin="0,0,0,8"/>
                        <Label Text="No events yet" TextColor="Gray" FontSize="13" HorizontalOptions="Center"/>
                        <Label Text="Events will appear in real-time as the agent works" 
                               TextColor="Gray" FontSize="11" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:AgentEvent">
                        <Border Margin="2,2" Padding="8,6" StrokeShape="RoundRectangle 6"
                                Stroke="Transparent"
                                BackgroundColor="{AppThemeBinding Light=#f8f8fc, Dark=#1a1a2e}">
                            <Grid ColumnDefinitions="50,*" ColumnSpacing="8">
                                <Label Text="{Binding Timestamp, StringFormat='{0:mm:ss.f}'}" 
                                       FontSize="9" TextColor="Gray" VerticalOptions="Start"
                                       FontFamily="Courier New"/>
                                <VerticalStackLayout Grid.Column="1" Spacing="2">
                                    <Label Text="{Binding Type}" FontSize="11" 
                                           FontAttributes="Bold"
                                           TextColor="{Binding Type, Converter={StaticResource EventTypeColorConverter}}"/>
                                    <Label Text="{Binding Description}" FontSize="10" 
                                           TextColor="{AppThemeBinding Light=#555, Dark=#999}"
                                           LineBreakMode="TailTruncation" MaxLines="2"/>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Traces Tab Content -->
            <CollectionView Grid.Row="1" ItemsSource="{Binding Traces}" Margin="8,4"
                            IsVisible="{Binding IsTracesTab}">
                <CollectionView.EmptyView>
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Padding="20">
                        <Label Text="🔍" FontSize="28" HorizontalOptions="Center" Margin="0,0,0,8"/>
                        <Label Text="No traces yet" TextColor="Gray" FontSize="13" HorizontalOptions="Center"/>
                        <Label Text="OpenTelemetry traces will appear here" 
                               TextColor="Gray" FontSize="11" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:TraceSpan">
                        <Border Margin="2,2" Padding="8,6" StrokeShape="RoundRectangle 6"
                                Stroke="Transparent"
                                BackgroundColor="{AppThemeBinding Light=#f8f8fc, Dark=#1a1a2e}">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                <Border StrokeShape="RoundRectangle 3" Padding="4,2"
                                        BackgroundColor="{Binding OperationColor}" StrokeThickness="0">
                                    <Label Text="{Binding OperationKind}" FontSize="8" TextColor="White"/>
                                </Border>
                                <Label Grid.Column="1" Text="{Binding Name}" FontSize="11"
                                       TextColor="{AppThemeBinding Light=#333, Dark=#ccc}"
                                       LineBreakMode="TailTruncation" VerticalOptions="Center"/>
                                <Label Grid.Column="2" Text="{Binding Duration, StringFormat='{0}ms'}" 
                                       FontSize="9" TextColor="Gray" VerticalOptions="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Tools Tab Content -->
            <CollectionView Grid.Row="1" ItemsSource="{Binding ToolCalls}" Margin="8,4"
                            IsVisible="{Binding IsToolsTab}">
                <CollectionView.EmptyView>
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Padding="20">
                        <Label Text="🔧" FontSize="28" HorizontalOptions="Center" Margin="0,0,0,8"/>
                        <Label Text="No tool calls yet" TextColor="Gray" FontSize="13" HorizontalOptions="Center"/>
                        <Label Text="Function calls and tool invocations appear here" 
                               TextColor="Gray" FontSize="11" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:ToolCall">
                        <Border Margin="2,2" Padding="10,8" StrokeShape="RoundRectangle 6"
                                Stroke="Transparent"
                                BackgroundColor="{AppThemeBinding Light=#f8f8fc, Dark=#1a1a2e}">
                            <VerticalStackLayout Spacing="4">
                                <HorizontalStackLayout Spacing="6">
                                    <Label Text="⚡" FontSize="11"/>
                                    <Label Text="{Binding Name}" FontSize="12" FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light=#3B82F6, Dark=#60A5FA}"/>
                                    <Label Text="{Binding Timestamp, StringFormat='{0:h:mm:ss}'}" 
                                           FontSize="9" TextColor="Gray" VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                                <Label Text="{Binding Arguments}" FontSize="10" 
                                       TextColor="{AppThemeBinding Light=#666, Dark=#888}"
                                       FontFamily="Courier New"
                                       LineBreakMode="TailTruncation" MaxLines="3"/>
                                <Label Text="{Binding Result}" FontSize="10"
                                       TextColor="#10B981" IsVisible="{Binding Result, Converter={StaticResource NotNullConverter}}"
                                       LineBreakMode="TailTruncation" MaxLines="2"/>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Footer -->
            <Border Grid.Row="2" Padding="12,8" StrokeThickness="0"
                    BackgroundColor="{AppThemeBinding Light=#f0eef5, Dark=#16162a}">
                <HorizontalStackLayout Spacing="16">
                    <Label Text="{Binding TotalTokens, StringFormat='Tokens: {0}'}" 
                           FontSize="10" TextColor="Gray"/>
                    <Label Text="{Binding ElapsedTime, StringFormat='Time: {0}'}" 
                           FontSize="10" TextColor="Gray"/>
                </HorizontalStackLayout>
            </Border>
        </Grid>
    </Grid>

</ContentPage>
